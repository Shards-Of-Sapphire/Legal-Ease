# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=1

# Session Security (REQUIRED FOR PRODUCTION)
# Generate a random 32+ character string for production
# Use: python -c 'import secrets; print(secrets.token_hex(32))'
SESSION_SECRET=your-secret-key-here-min-32-chars-random-string

# Database Configuration
# For local development (uses SQLite by default if not set):
# DATABASE_URL=sqlite:///history.db

# For PostgreSQL (production):
# DATABASE_URL=postgresql://user:password@localhost:5432/legal_ease_db

# For production on Render:
# DATABASE_URL=<provided-by-render>

# Optional: OCR Service (for camera feature)
# If using pytesseract, ensure tesseract-ocr is installed:
# Ubuntu: sudo apt-get install tesseract-ocr
# macOS: brew install tesseract
TESSERACT_PATH=

# Optional: File Upload Location (default: ./uploads)
UPLOAD_FOLDER=uploads

# Optional: Max file size (in bytes, default: 16MB)
MAX_CONTENT_LENGTH=16777216

# Optional: Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=DEBUG

# Optional: Email Configuration (for future features)
# MAIL_SERVER=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USE_TLS=true
# MAIL_USERNAME=your-email@gmail.com
# MAIL_PASSWORD=your-app-password
